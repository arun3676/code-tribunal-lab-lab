# Copy to .env at the repo root for docker compose local development.
# See DEPLOYMENT.md for production (Railway + Vercel).

# --- LLM providers (apps/api) ---
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
MERCURY_API_KEY=
Kimi_API_KEY=

# --- Frontend (apps/web via docker-compose) ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- API CORS ---
ALLOWED_ORIGINS=http://localhost:3000
# ALLOWED_ORIGIN_REGEX=https://.*\.vercel\.app

# --- Tribunal / Band (add when building hackathon mode) ---
# BAND_ENABLED=true
# BAND_API_KEY=
# AIMLAPI_API_KEY=
# FEATHERLESS_API_KEY=
